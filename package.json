    "test": "vitest run",
    "test:watch": "vitest --browser --watch --open",
    "test:ci": "vitest run --coverage",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run"
  },
  "author": "Zextras <https://www.zextras.com>",
  "license": "ISC",
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
