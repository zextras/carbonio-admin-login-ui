    "eslint-plugin-wc": "^3.1.0",
    "jsdom": "^26.0.0",
    "lit": "^3.3.2",
    "lit-analyzer": "^2.0.3",
    "msw": "^2.3.2",
    "playwright": "^1.59.1",
    "semantic-release": "^25.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "sonarqube-scanner": "^3.2.0",
    "ts-lit-plugin": "^2.0.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.49.0",
    "unplugin-swc": "^1.5.9",
