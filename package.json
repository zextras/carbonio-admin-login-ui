  "description": "Zextras authentication App",
  "type": "module",
  "main": "src/index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode='development'",
    "reset": "node ./scripts/reset.js",
    "deploy": "node ./scripts/deploy.js",
    "deploy:dev": "node ./scripts/deploy.js development",
