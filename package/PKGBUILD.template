# Zextras Login Page
# This package contains the assets for the browser login page

pkgname="carbonio-admin-login-ui"
pkgver="{{version}}"
pkgrel="{{pkgRel}}"
pkgdesc="Carbonio admin login page assets"
maintainer="Zextras <packages@zextras.com>"
arch=('x86_64')
license=("AGPL-3.0-only")
section="admin"
priority="optional"
url="https://www.zextras.com/"
depends=(
  "carbonio-nginx"
  "carbonio-webui-i18n"
)
source=(
  "${pkgname}-dist.tar.gz"
)
sha256sums=(
  'SKIP'
)

package() {
  install -dm755 \
    "${pkgdir}/opt/zextras/admin/login/"
  cp -a "${srcdir}/dist/"* \
    "${pkgdir}/opt/zextras/admin/login"
  ln -s /opt/zextras/admin/login-i18n \
    "${pkgdir}/opt/zextras/admin/login/i18n"
}

preinst() {
  if [ -d /opt/zextras/admin/login/i18n ]; then
    rm -rf /opt/zextras/admin/login/i18n
  fi
}

postinst() {
  chown root:root -R /opt/zextras/admin/login
  chmod 755 -R /opt/zextras/admin/login
}
